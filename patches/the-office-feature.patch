diff --git a/ui/src/pages/TheOffice.tsx b/ui/src/pages/TheOffice.tsx
new file mode 100644
index 0000000..3304bc1
--- /dev/null
+++ b/ui/src/pages/TheOffice.tsx
@@ -0,0 +1,78 @@
+import { useEffect, useMemo } from "react";
+import { useQuery } from "@tanstack/react-query";
+import { useCompany } from "@/context/CompanyContext";
+import { useBreadcrumbs } from "@/context/BreadcrumbContext";
+import { pluginsApi } from "@/api/plugins";
+import { queryKeys } from "@/lib/queryKeys";
+import { PluginSlotMount } from "@/plugins/slots";
+
+export function TheOffice() {
+  const { selectedCompanyId, selectedCompany } = useCompany();
+  const { setBreadcrumbs } = useBreadcrumbs();
+
+  const { data: contributions } = useQuery({
+    queryKey: queryKeys.plugins.uiContributions,
+    queryFn: () => pluginsApi.listUiContributions(),
+    enabled: !!selectedCompanyId,
+  });
+
+  const agentPixelsSlot = useMemo(() => {
+    if (!contributions) return null;
+    for (const contribution of contributions) {
+      const slot = contribution.slots.find((s) => s.type === "page");
+      if (!slot) continue;
+      if (contribution.displayName.toLowerCase().includes("pixel")) {
+        return {
+          ...slot,
+          pluginId: contribution.pluginId,
+          pluginKey: contribution.pluginKey,
+          pluginDisplayName: contribution.displayName,
+          pluginVersion: contribution.version,
+        };
+      }
+    }
+    return null;
+  }, [contributions]);
+
+  useEffect(() => {
+    setBreadcrumbs([{ label: "The Office" }]);
+  }, [setBreadcrumbs]);
+
+  const context = useMemo(
+    () => ({
+      companyId: selectedCompanyId ?? null,
+      companyPrefix: selectedCompany?.issuePrefix ?? null,
+    }),
+    [selectedCompanyId, selectedCompany],
+  );
+
+  if (!contributions) {
+    return <div className="text-sm text-muted-foreground">Loading…</div>;
+  }
+
+  if (!agentPixelsSlot) {
+    return (
+      <div className="space-y-3">
+        <h1 className="text-xl font-semibold">The Office</h1>
+        <div className="rounded-md border border-border bg-muted/20 px-4 py-8 text-center">
+          <p className="text-sm text-muted-foreground">Agent Pixels plugin is not installed.</p>
+          <p className="mt-1 text-xs text-muted-foreground">
+            Install it from the Plugin Manager to see your agents at work.
+          </p>
+        </div>
+      </div>
+    );
+  }
+
+  return (
+    <div className="space-y-4">
+      <h1 className="text-xl font-semibold">The Office</h1>
+      <PluginSlotMount
+        slot={agentPixelsSlot}
+        context={context}
+        className="min-h-[400px]"
+        missingBehavior="placeholder"
+      />
+    </div>
+  );
+}
