diff --git a/scripts/docker-entrypoint.sh b/scripts/docker-entrypoint.sh
index 8187875..96aa692 100644
--- a/scripts/docker-entrypoint.sh
+++ b/scripts/docker-entrypoint.sh
@@ -39,4 +39,16 @@ if [ "$changed" = "1" ]; then
     chown -R node:node /paperclip
 fi
 
+# Auto-install bundled Agent-Pixels plugin into the runtime plugins directory
+BUNDLED_PLUGIN="/app/bundled-plugins/agent-pixels"
+PLUGINS_DIR="/paperclip/.paperclip/plugins"
+PLUGIN_DEST="$PLUGINS_DIR/agent-pixels"
+
+if [ -d "$BUNDLED_PLUGIN" ] && [ ! -d "$PLUGIN_DEST" ]; then
+  echo "Installing bundled Agent-Pixels plugin..."
+  mkdir -p "$PLUGINS_DIR"
+  cp -r "$BUNDLED_PLUGIN" "$PLUGIN_DEST"
+  chown -R node:node "$PLUGINS_DIR"
+fi
+
 exec gosu node "$@"
