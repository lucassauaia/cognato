# ── Paperclip (Management Layer) ──────────────────────────────────────────────
PAPERCLIP_PORT=3100
BETTER_AUTH_SECRET=<run: openssl rand -hex 32>
PAPERCLIP_PUBLIC_URL=http://localhost:3100
DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip

# ── OpenClaw (Execution / Gateway Layer) ──────────────────────────────────────
OPENCLAW_PORT=18789
OPENCLAW_DATA_DIR=/data
# Token mode (recommended for production — Bearer header, programmatic access)
# Generate: openssl rand -hex 32
# Docs: https://docs.openclaw.ai/gateway/configuration-reference
OPENCLAW_GATEWAY_TOKEN=<run: openssl rand -hex 32>
# Password mode (interactive sessions only — mutually exclusive with TOKEN)
# OPENCLAW_GATEWAY_PASSWORD=<set-a-strong-password>

# ── Hermes (Memory / Learning Layer) ──────────────────────────────────────────
HERMES_PORT=8642
HERMES_DATA_DIR=/opt/data

# ── Shared API Keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip
POSTGRES_DB=paperclip
POSTGRES_PORT=5432
